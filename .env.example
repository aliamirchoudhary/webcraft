# ================================================================
#  WebCraft – Environment Variables
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit .env to Git — it contains your passwords!
# ================================================================

# ── Server ──────────────────────────────────────────────────────
PORT=3000

# ── YOUR Gmail credentials (see setup guide in server.js) ───────
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Where admin emails are delivered ────────────────────────────
ADMIN_EMAIL=yourgmail@gmail.com

# ── Abstract API – free email validation ────────────────────────
# Sign up FREE at: https://www.abstractapi.com/api/email-verification-validation-api
# 100 requests / month on free tier — enough for a portfolio site
ABSTRACT_API_KEY=your_abstract_api_key_here

# ── Frontend origin (for CORS) ───────────────────────────────────
# During local dev use: http://localhost:3000
# On production replace with your real domain e.g. https://webcraft.dev
FRONTEND_ORIGIN=http://localhost:3000
